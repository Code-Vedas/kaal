#!/bin/sh

if [ "${SCRIPT_DIR:-}" = "" ]; then
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
fi
. "${SCRIPT_DIR}/run-common"

run_suite() {
  suite_name="$1"
  suite_dir="$2"

  cd "${REPO_ROOT}/${suite_dir}"

  if gemfiles=$(suite_gemfiles "${suite_dir}"); then
    for gemfile in ${gemfiles}; do
      label=$(gemfile_label "${gemfile}")
      RUN_ALL_EXPECT_RAILS=1 RUN_ALL_BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" run_cmd_env \
        "${suite_name}-${label}-rspec-e2e-memory" \
        BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" \
        bin/rspec-e2e memory
      RUN_ALL_EXPECT_RAILS=1 RUN_ALL_BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" run_cmd_env \
        "${suite_name}-${label}-rspec-e2e-redis" \
        BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" \
        REDIS_URL="redis://127.0.0.1:6379/0" \
        bin/rspec-e2e redis
      RUN_ALL_EXPECT_RAILS=1 RUN_ALL_BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" run_cmd_env \
        "${suite_name}-${label}-rspec-e2e-sqlite" \
        BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" \
        bin/rspec-e2e sqlite
      RUN_ALL_EXPECT_RAILS=1 RUN_ALL_BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" run_cmd_env \
        "${suite_name}-${label}-rspec-e2e-postgres" \
        BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" \
        DATABASE_URL="postgres://postgres:postgres@localhost:5432/kaal_test_auto" \
        bin/rspec-e2e pg
      RUN_ALL_EXPECT_RAILS=1 RUN_ALL_BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" run_cmd_env \
        "${suite_name}-${label}-rspec-e2e-mysql" \
        BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" \
        DATABASE_URL="mysql2://root:rootROOT!1@127.0.0.1:3306/kaal_test_auto" \
        bin/rspec-e2e mysql
    done
    return 0
  fi

  run_cmd "${suite_name}-rspec-e2e-memory" bin/rspec-e2e memory
  run_cmd_env \
    "${suite_name}-rspec-e2e-redis" \
    REDIS_URL="redis://127.0.0.1:6379/0" \
    bin/rspec-e2e redis
  run_cmd "${suite_name}-rspec-e2e-sqlite" bin/rspec-e2e sqlite
  run_cmd_env \
    "${suite_name}-rspec-e2e-postgres" \
    DATABASE_URL="postgres://postgres:postgres@localhost:5432/kaal_test_auto" \
    bin/rspec-e2e pg
  run_cmd_env \
    "${suite_name}-rspec-e2e-mysql" \
    DATABASE_URL="mysql2://root:rootROOT!1@127.0.0.1:3306/kaal_test_auto" \
    bin/rspec-e2e mysql
}

if [ "${0##*/}" = "run-rspec-e2e-all" ]; then
  run_suite "kaal" "core/kaal"
  run_suite "kaal-activerecord" "core/kaal-activerecord"
  run_suite "kaal-sequel" "core/kaal-sequel"
  run_suite "kaal-hanami" "gems/kaal-hanami"
  run_suite "kaal-rails" "gems/kaal-rails"
  run_suite "kaal-roda" "gems/kaal-roda"
  run_suite "kaal-sinatra" "gems/kaal-sinatra"
fi
